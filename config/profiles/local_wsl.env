# VermAMG local WSL profile
# Source via:
#   source scripts/utils/load_vermamg_profile.sh local_wsl
#
# Design rule:
# Local profile is for local smoke/regression testing.
# Heavy prediction can be precomputed or skipped.

export VERMAMG_PROFILE="local_wsl"
export EXECUTION_BACKEND="local"

# Keep local root auto-detectable by loader if unset.
export VERMAMG_ROOT="${VERMAMG_ROOT:-}"

# Local database/cache root.
export VERMAMG_DB_ROOT="${VERMAMG_ROOT}/resources/databases"

export PYTHON_BIN="${PYTHON_BIN:-python3}"
export RESULTS_ROOT="${RESULTS_ROOT:-results}"
export WORK_ROOT="${WORK_ROOT:-work}"
export RUN_SET_ROOT="${RUN_SET_ROOT:-${VERMAMG_ROOT}/run_sets}"
export COLABFOLD_QC_TABLE_ROOT="${COLABFOLD_QC_TABLE_ROOT:-${VERMAMG_ROOT}/01_colabfold/qc_tables}"
export FOLDSEEK_ROOT="${FOLDSEEK_ROOT:-${VERMAMG_ROOT}/02_foldseek}"

# Structure prediction is GPU/database heavy.
export COLABFOLD_BACKEND="apptainer"
export COLABFOLD_CMD="${COLABFOLD_CMD:-colabfold_batch}"
export COLABFOLD_DATA="${VERMAMG_ROOT}/resources/databases/colabfold/colabfold_data"
export COLABFOLD_CONTAINER="${VERMAMG_ROOT}/resources/containers/colabfold_1.6.1-cuda12.sif"

# Foldseek
export FOLDSEEK_BIN="${VERMAMG_ROOT}/resources/tools/foldseek/bin/foldseek"
export PDB_FOLDSEEK_DB="${VERMAMG_ROOT}/resources/databases/foldseek/pdb/pdb"
export AFSP_FOLDSEEK_DB="${VERMAMG_ROOT}/resources/databases/foldseek/alphafold_swissprot/af_swissprot"

# P2Rank
export JAVA_BIN="${JAVA_BIN:-java}"
export P2RANK_HOME="${VERMAMG_ROOT}/resources/tools/p2rank/p2rank_2.5.1"
export P2RANK_JAR="${P2RANK_HOME}/bin/p2rank.jar"
export P2RANK_CMD="${P2RANK_HOME}/prank"

# Rendering
# CHIMERAX_CMD is optional for local visual inspection.
export PYMOL_CMD="${VERMAMG_ROOT}/scripts/utils/pymol_apptainer_wrapper.sh"
export PYMOL_CONTAINER="${VERMAMG_ROOT}/resources/containers/pymol_deb12_2.5.0_sc.sif"
export CHIMERAX_CMD="${CHIMERAX_CMD:-chimerax}"

# SLURM ignored locally
export SLURM_ACCOUNT=""
export SLURM_PARTITION_CPU=""
export SLURM_PARTITION_DEBUG=""
export SLURM_PARTITION_GPU=""
export SLURM_CPUS="${SLURM_CPUS:-4}"
export SLURM_MEM="${SLURM_MEM:-16G}"
export SLURM_TIME_CPU="${SLURM_TIME_CPU:-12:00:00}"
export SLURM_TIME_GPU="${SLURM_TIME_GPU:-12:00:00}"

# VermAMG portability/resource roots and M10F visual render profile keys
# Added by ADIM_4AR; safe defaults, no execution.
export VERMAMG_TOOLS_ROOT="${VERMAMG_ROOT}/resources/tools"
export VERMAMG_DATABASES_ROOT="${VERMAMG_ROOT}/resources/databases"
export M10F_CANONICAL_RUN_DIR="${M10F_CANONICAL_RUN_DIR:-06_visual_qc_v6/regression/canonical_v6_engine_regression}"
export M10F_RENDER_ENV_DIR="${M10F_RENDER_ENV_DIR:-06_visual_qc_v6/render_env}"
export M10F_RENDER_BACKEND="${M10F_RENDER_BACKEND:-pymol}"
export M10F_ENABLE_RENDER_SUBMIT="${M10F_ENABLE_RENDER_SUBMIT:-0}"
export PYMOL_PYDEPS_ROOT="${VERMAMG_ROOT}/resources/tools/pymol_pydeps"
export PYMOL_PIL_SITE="${VERMAMG_ROOT}/resources/tools/pymol_pydeps/lib/python3.9/site-packages"

# VermAMG internalized resource paths
export VERMAMG_CONTAINERS_ROOT="${VERMAMG_ROOT}/resources/containers"
export VERMAMG_FOLDSEEK_BIN="${VERMAMG_ROOT}/resources/tools/foldseek/bin/foldseek"
export VERMAMG_P2RANK_HOME="${VERMAMG_ROOT}/resources/tools/p2rank/p2rank_2.5.1"
export VERMAMG_P2RANK_JAR="${VERMAMG_ROOT}/resources/tools/p2rank/p2rank_2.5.1/bin/p2rank.jar"
export VERMAMG_PDB_FOLDSEEK_DB="${VERMAMG_ROOT}/resources/databases/foldseek/pdb/pdb"
export VERMAMG_AFSP_FOLDSEEK_DB="${VERMAMG_ROOT}/resources/databases/foldseek/alphafold_swissprot/af_swissprot"
export VERMAMG_COLABFOLD_SIF="${VERMAMG_ROOT}/resources/containers/colabfold_1.6.1-cuda12.sif"
export VERMAMG_PYMOL_SIF="${VERMAMG_ROOT}/resources/containers/pymol_deb12_2.5.0_sc.sif"
export VERMAMG_PYMOL_PYDEPS_ROOT="${VERMAMG_ROOT}/resources/tools/pymol_pydeps"
export VERMAMG_PYMOL_PIL_SITE="${VERMAMG_ROOT}/resources/tools/pymol_pydeps/lib/python3.9/site-packages"
export VERMAMG_M10F_RENDER_ENV_DIR="${VERMAMG_ROOT}/06_visual_qc_v6/render_env"
export VERMAMG_M10F_PYMOL_CMD="${VERMAMG_ROOT}/scripts/utils/pymol_apptainer_wrapper.sh"

# M10G composite figure render — local_wsl support
# Set M10G_RENDER_ENABLE=1 to activate local composite PNG generation via 10g.
export M10G_RENDER_ENABLE="${M10G_RENDER_ENABLE:-1}"
export M10G_FRESH_RUN_REL="${M10G_FRESH_RUN_REL:-runs/smoke_precomputed/smoke_3prot_v1}"
export M10G_N_PARALLEL="${M10G_N_PARALLEL:-4}"
export M10G_SMOKE_LIMIT="${M10G_SMOKE_LIMIT:-3}"

# M09H-M09R topology/catalytic previsual layer.
# Local profile stays dry-run/scaffold unless explicitly enabled in a run config.
export DEEPTMHMM_RESULTS_DIR="${DEEPTMHMM_RESULTS_DIR:-}"
export MCSA_RESOURCE_ROOT="${MCSA_RESOURCE_ROOT:-${VERMAMG_ROOT}/resources/databases/mcsa/current}"
export MCSA_SNAPSHOT_ID="${MCSA_SNAPSHOT_ID:-current}"
export MCSA_DOWNLOAD_ENABLE="${MCSA_DOWNLOAD_ENABLE:-0}"
export UNIPROT_RESOURCE_ROOT="${UNIPROT_RESOURCE_ROOT:-${VERMAMG_ROOT}/resources/databases/uniprot/current}"
export UNIPROT_DOWNLOAD_ENABLE="${UNIPROT_DOWNLOAD_ENABLE:-0}"
export RCSB_ORIGINAL_PDB_CACHE="${RCSB_ORIGINAL_PDB_CACHE:-${VERMAMG_ROOT}/resources/databases/rcsb/original_pdb}"
# Golden row-count expectations are count-agnostic by default (0 = not enforced).
# Set these to your dataset's known counts only for golden-regression validation.
export CATALYTIC_LAYER_STRICT_QUERY_N="${CATALYTIC_LAYER_STRICT_QUERY_N:-0}"
export CATALYTIC_LAYER_STRICT_REFERENCE_RETENTION="${CATALYTIC_LAYER_STRICT_REFERENCE_RETENTION:-1}"
export CATALYTIC_VALIDATION_MODE="${CATALYTIC_VALIDATION_MODE:-precomputed}"
export CATALYTIC_EXPECTED_VERSION="${CATALYTIC_EXPECTED_VERSION:-A10G_FIX2}"
export CATALYTIC_EXPECTED_QUERY_COUNT="${CATALYTIC_EXPECTED_QUERY_COUNT:-0}"
export CATALYTIC_EXPECTED_RESIDUE_ROWS="${CATALYTIC_EXPECTED_RESIDUE_ROWS:-0}"
export CATALYTIC_EXPECTED_MANUAL_OVERRIDE_ROWS="${CATALYTIC_EXPECTED_MANUAL_OVERRIDE_ROWS:-0}"
export CATALYTIC_PAIRWISE_ALIGN_GENERATE_JOBS_ONLY="${CATALYTIC_PAIRWISE_ALIGN_GENERATE_JOBS_ONLY:-1}"
export CATALYTIC_PAIRWISE_ALIGN_SMOKE_PARTITION="${CATALYTIC_PAIRWISE_ALIGN_SMOKE_PARTITION:-debug}"
export CATALYTIC_PAIRWISE_ALIGN_FULL_PARTITION="${CATALYTIC_PAIRWISE_ALIGN_FULL_PARTITION:-compute}"
