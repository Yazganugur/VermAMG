# VermAMG TRUBA/HPC profile
# Source via:
#   source scripts/utils/load_vermamg_profile.sh truba
#
# Design rule:
# TRUBA profile must force TRUBA/scratch paths for validated HPC workflow.
# User overrides should be added later via a separate local override file, not by inherited shell state.

export VERMAMG_PROFILE="truba"
export EXECUTION_BACKEND="slurm"

# Current validated TRUBA project root.
export VERMAMG_ROOT="/arf/scratch/yugur/baps_faz_c_v2/structural_validation_tier1_full"

# Current validated TRUBA database/cache/runtime root.
# IMPORTANT: this must stay on scratch, not /arf/home.
export VERMAMG_DB_ROOT="/arf/scratch/yugur/baps_faz_c_v2/structural_validation"

export PYTHON_BIN="${PYTHON_BIN:-python3}"
export RESULTS_ROOT="${RESULTS_ROOT:-results}"
export WORK_ROOT="${WORK_ROOT:-work}"
export RUN_SET_ROOT="${RUN_SET_ROOT:-${VERMAMG_ROOT}/run_sets}"
export COLABFOLD_QC_TABLE_ROOT="${COLABFOLD_QC_TABLE_ROOT:-${VERMAMG_ROOT}/01_colabfold/qc_tables}"
export FOLDSEEK_ROOT="${FOLDSEEK_ROOT:-${VERMAMG_ROOT}/02_foldseek}"

# ColabFold / AlphaFold
export COLABFOLD_BACKEND="apptainer"
export COLABFOLD_CMD="${COLABFOLD_CMD:-colabfold_batch}"
export COLABFOLD_DATA="$VERMAMG_DB_ROOT/colabfold_data"
export COLABFOLD_CONTAINER="/arf/home/yugur/containers/colabfold_1.6.1-cuda12.sif"

# Foldseek
export FOLDSEEK_BIN="/arf/home/yugur/tools/foldseek_tm_tools/foldseek/bin/foldseek"
export PDB_FOLDSEEK_DB="$VERMAMG_DB_ROOT/foldseek_tm_align/refdb/pdb/pdb"
export AFSP_FOLDSEEK_DB="$VERMAMG_DB_ROOT/foldseek_tm_align/refdb/alphafold_swissprot/af_swissprot"

# P2Rank
export JAVA_BIN="${JAVA_BIN:-java}"
export P2RANK_HOME="/arf/scratch/yugur/baps_faz_c_v2/structural_validation/pocket_validation/tools/p2rank_extracted/p2rank_2.5.1"
export P2RANK_JAR="$P2RANK_HOME/bin/p2rank.jar"
export P2RANK_CMD="$P2RANK_HOME/prank"

# Visual rendering
export PYMOL_CMD="$VERMAMG_ROOT/06_visual_qc_v6/render_env/bin/pymol"
export PYMOL_CONTAINER="/arf/home/yugur/containers/pymol_deb12_2.5.0_sc.sif"
export CHIMERAX_CMD="${CHIMERAX_CMD:-chimerax}"

# SLURM/TRUBA
export SLURM_ACCOUNT="yugur"
export SLURM_PARTITION_CPU="barbun"
export SLURM_PARTITION_DEBUG="debug"
export SLURM_PARTITION_GPU="barbun-cuda"
export SLURM_CPUS="${SLURM_CPUS:-20}"
export SLURM_MEM="${SLURM_MEM:-64G}"
export SLURM_TIME_CPU="${SLURM_TIME_CPU:-12:00:00}"
export SLURM_TIME_GPU="${SLURM_TIME_GPU:-12:00:00}"

# M09D P2Rank SLURM defaults.
# P2Rank small jobs can use debug; override for longer/full runs or dedicated hamsi profiles.
export P2RANK_SLURM_ACCOUNT="${P2RANK_SLURM_ACCOUNT:-${SLURM_ACCOUNT:-yugur}}"
export P2RANK_SLURM_PARTITION="${P2RANK_SLURM_PARTITION:-${SLURM_PARTITION_CPU:-debug}}"
export P2RANK_SLURM_CPUS="${P2RANK_SLURM_CPUS:-8}"
export P2RANK_SLURM_MEM="${P2RANK_SLURM_MEM:-16G}"
export P2RANK_SLURM_TIME="${P2RANK_SLURM_TIME:-01:00:00}"

# M06 Foldseek PDB SLURM defaults.
# Hamsi requires a 56-core override; use a dedicated profile or explicit env override.
export FOLDSEEK_PDB_SLURM_ACCOUNT="${FOLDSEEK_PDB_SLURM_ACCOUNT:-${SLURM_ACCOUNT:-yugur}}"
export FOLDSEEK_PDB_SLURM_PARTITION="${FOLDSEEK_PDB_SLURM_PARTITION:-${SLURM_PARTITION_CPU:-barbun}}"
export FOLDSEEK_PDB_SLURM_CPUS="${FOLDSEEK_PDB_SLURM_CPUS:-20}"
export FOLDSEEK_PDB_SLURM_MEM="${FOLDSEEK_PDB_SLURM_MEM:-64G}"
export FOLDSEEK_PDB_SLURM_TIME="${FOLDSEEK_PDB_SLURM_TIME:-3-00:00:00}"
export FOLDSEEK_PDB_THREADS="${FOLDSEEK_PDB_THREADS:-${FOLDSEEK_PDB_SLURM_CPUS}}"

# M07 Foldseek AFSP SLURM defaults.
# Hamsi requires a 56-core override; use a dedicated profile or explicit env override.
export FOLDSEEK_AFSP_SLURM_ACCOUNT="${FOLDSEEK_AFSP_SLURM_ACCOUNT:-${SLURM_ACCOUNT:-yugur}}"
export FOLDSEEK_AFSP_SLURM_PARTITION="${FOLDSEEK_AFSP_SLURM_PARTITION:-${SLURM_PARTITION_CPU:-barbun}}"
export FOLDSEEK_AFSP_SLURM_CPUS="${FOLDSEEK_AFSP_SLURM_CPUS:-20}"
export FOLDSEEK_AFSP_SLURM_MEM="${FOLDSEEK_AFSP_SLURM_MEM:-64G}"
export FOLDSEEK_AFSP_SLURM_TIME="${FOLDSEEK_AFSP_SLURM_TIME:-3-00:00:00}"
export FOLDSEEK_AFSP_THREADS="${FOLDSEEK_AFSP_THREADS:-${FOLDSEEK_AFSP_SLURM_CPUS}}"

# VermAMG portability/resource roots and M10F visual render profile keys
# Added by ADIM_4AR; safe defaults, no execution.
export VERMAMG_TOOLS_ROOT="${VERMAMG_ROOT}/resources/tools"
export VERMAMG_DATABASES_ROOT="${VERMAMG_ROOT}/resources/databases"
export M10F_CANONICAL_RUN_DIR="${M10F_CANONICAL_RUN_DIR:-06_visual_qc_v6/regression/canonical_v6_engine_all32_regression}"
export M10F_RENDER_ENV_DIR="${M10F_RENDER_ENV_DIR:-06_visual_qc_v6/render_env}"
export M10F_RENDER_BACKEND="${M10F_RENDER_BACKEND:-pymol}"
export M10F_ENABLE_RENDER_SUBMIT="${M10F_ENABLE_RENDER_SUBMIT:-0}"
export PYMOL_PYDEPS_ROOT="${VERMAMG_ROOT}/resources/tools/pymol_pydeps"
export PYMOL_PIL_SITE="${VERMAMG_ROOT}/resources/tools/pymol_pydeps/lib/python3.9/site-packages"

# VermAMG internalized resource paths
export VERMAMG_CONTAINERS_ROOT="${VERMAMG_ROOT}/resources/containers"
export VERMAMG_FOLDSEEK_BIN="${VERMAMG_ROOT}/resources/tools/foldseek/bin/foldseek"
export VERMAMG_P2RANK_HOME="${VERMAMG_ROOT}/resources/tools/p2rank/p2rank_2.5.1"
export VERMAMG_P2RANK_JAR="${VERMAMG_ROOT}/resources/tools/p2rank/p2rank_2.5.1/bin/p2rank.jar"
export VERMAMG_PDB_FOLDSEEK_DB="${VERMAMG_ROOT}/resources/databases/foldseek/pdb/pdb"
export VERMAMG_AFSP_FOLDSEEK_DB="${VERMAMG_ROOT}/resources/databases/foldseek/alphafold_swissprot/af_swissprot"
export VERMAMG_COLABFOLD_SIF="${VERMAMG_ROOT}/resources/containers/colabfold_1.6.1-cuda12.sif"
export VERMAMG_PYMOL_SIF="${VERMAMG_ROOT}/resources/containers/pymol_deb12_2.5.0_sc.sif"
export VERMAMG_PYMOL_PYDEPS_ROOT="${VERMAMG_ROOT}/resources/tools/pymol_pydeps"
export VERMAMG_PYMOL_PIL_SITE="${VERMAMG_ROOT}/resources/tools/pymol_pydeps/lib/python3.9/site-packages"
export VERMAMG_M10F_RENDER_ENV_DIR="${VERMAMG_ROOT}/06_visual_qc_v6/render_env"
export VERMAMG_M10F_PYMOL_CMD="${VERMAMG_ROOT}/06_visual_qc_v6/render_env/bin/pymol"

# M09H-M09R topology/catalytic previsual layer.
# Phase 1 is scaffold/cache-check only; future test compute must use debug.
export DEEPTMHMM_RESULTS_DIR="${DEEPTMHMM_RESULTS_DIR:-}"
export MCSA_RESOURCE_ROOT="${MCSA_RESOURCE_ROOT:-${VERMAMG_ROOT}/resources/databases/mcsa/current}"
export MCSA_SNAPSHOT_ID="${MCSA_SNAPSHOT_ID:-current}"
export MCSA_DOWNLOAD_ENABLE="${MCSA_DOWNLOAD_ENABLE:-0}"
export UNIPROT_RESOURCE_ROOT="${UNIPROT_RESOURCE_ROOT:-${VERMAMG_ROOT}/resources/databases/uniprot/current}"
export UNIPROT_DOWNLOAD_ENABLE="${UNIPROT_DOWNLOAD_ENABLE:-0}"
export RCSB_ORIGINAL_PDB_CACHE="${RCSB_ORIGINAL_PDB_CACHE:-${VERMAMG_ROOT}/resources/databases/rcsb/original_pdb}"
export CATALYTIC_LAYER_STRICT_QUERY_N="${CATALYTIC_LAYER_STRICT_QUERY_N:-665}"
export CATALYTIC_LAYER_STRICT_REFERENCE_RETENTION="${CATALYTIC_LAYER_STRICT_REFERENCE_RETENTION:-1}"
export CATALYTIC_VALIDATION_MODE="${CATALYTIC_VALIDATION_MODE:-precomputed}"
export CATALYTIC_EXPECTED_VERSION="${CATALYTIC_EXPECTED_VERSION:-A10G_FIX2}"
export CATALYTIC_EXPECTED_QUERY_COUNT="${CATALYTIC_EXPECTED_QUERY_COUNT:-665}"
export CATALYTIC_EXPECTED_RESIDUE_ROWS="${CATALYTIC_EXPECTED_RESIDUE_ROWS:-17659}"
export CATALYTIC_EXPECTED_MANUAL_OVERRIDE_ROWS="${CATALYTIC_EXPECTED_MANUAL_OVERRIDE_ROWS:-12}"
export CATALYTIC_PAIRWISE_ALIGN_GENERATE_JOBS_ONLY="${CATALYTIC_PAIRWISE_ALIGN_GENERATE_JOBS_ONLY:-1}"
export CATALYTIC_PAIRWISE_ALIGN_SMOKE_PARTITION="${CATALYTIC_PAIRWISE_ALIGN_SMOKE_PARTITION:-${SLURM_PARTITION_DEBUG:-debug}}"
export CATALYTIC_PAIRWISE_ALIGN_FULL_PARTITION="${CATALYTIC_PAIRWISE_ALIGN_FULL_PARTITION:-${SLURM_PARTITION_CPU:-barbun}}"
