# BAPS Faz C v2 — Structural Validation Master Pipeline Config
# Generic mode names:
# test       = single-protein test run
# regression = known control set / reproducibility set
# full       = full candidate set

PROJECT_ROOT="${VERMAMG_ROOT}"

# Main candidate set
FULL_CANDIDATE_TABLE="${PROJECT_ROOT}/00_inputs/tier1_amg_with_habitat.tsv"
FULL_CANDIDATE_IDS="${PROJECT_ROOT}/00_inputs/tier1_protein_ids.txt"
FULL_CANDIDATE_FASTA="${PROJECT_ROOT}/00_inputs/tier1_amg.faa"
FULL_CANDIDATE_METADATA="${PROJECT_ROOT}/00_inputs/tier1_amg_sequence_metadata.tsv"

# Regression/control set
REGRESSION_FASTA="${PROJECT_ROOT}/09_regression_pilot32/tier1_pilot_balanced.faa"
REGRESSION_CANDIDATES="${PROJECT_ROOT}/09_regression_pilot32/tier1_pilot_balanced_candidates.tsv"
REGRESSION_OLD_DECISION="${PROJECT_ROOT}/09_regression_pilot32/old_pilot32_outputs/pilot32_final_candidate_decision_matrix.tsv"
REGRESSION_OLD_SECTION8="${PROJECT_ROOT}/09_regression_pilot32/old_pilot32_outputs/section8_final_compact_view_known_residue_refined.tsv"

# Optional test protein.
# For this BAPS run, this is a known Pilot32 CoA_trans control.
# For a general release, users can change this to any FASTA header ID in REGRESSION_FASTA or FULL_CANDIDATE_FASTA.
TEST_PROTEIN_ID="T1P001"

# Existing tools / resources from previous workflow
OLD_STRUCTURAL_ROOT="${VERMAMG_DB_ROOT}"
COLABFOLD_CONTAINER="${COLABFOLD_CONTAINER}"
COLABFOLD_DATA="${COLABFOLD_DATA}"
FOLDSEEK_BIN="${FOLDSEEK_BIN}"
P2RANK_JAR="${P2RANK_JAR:-${P2RANK_HOME}/bin/p2rank.jar}"

# Rulebook / visual resources
SECTION8_ROOT="${PROJECT_ROOT}/08_rulebook_evidence"
VISUAL_QC_ROOT="${PROJECT_ROOT}/06_visual_qc_v6"

# Output roots
COLABFOLD_OUT="${PROJECT_ROOT}/01_colabfold/outputs"
FOLDSEEK_OUT="${PROJECT_ROOT}/02_foldseek"
REFERENCE_OUT="${PROJECT_ROOT}/03_references"
P2RANK_OUT="${PROJECT_ROOT}/04_p2rank"
OVERLAY_OUT="${PROJECT_ROOT}/05_overlay_manifest"
VISUAL_OUT="${PROJECT_ROOT}/06_visual_qc_v6/tier1_outputs"
RESIDUE_OUT="${PROJECT_ROOT}/06_residue_level"
DECISION_OUT="${PROJECT_ROOT}/07_decision_matrix"
RULEBOOK_OUT="${PROJECT_ROOT}/08_rulebook_evidence/outputs_full"
REGRESSION_OUT="${PROJECT_ROOT}/09_regression_pilot32/new_run_comparison"
PACKAGE_OUT="${PROJECT_ROOT}/10_results_package"

# Test mode selection strategy
# first = select first sequence from regression FASTA
# exact = select TEST_PROTEIN_ID exactly/prefix-matching from regression FASTA
TEST_SELECTION_MODE="first"

# ColabFold batch preparation
COLABFOLD_BATCH_SIZE=8

# ColabFold run parameters
COLABFOLD_MSA_MODE="mmseqs2_uniref_env"
COLABFOLD_MODEL_TYPE="alphafold2_ptm"
COLABFOLD_NUM_RECYCLE=3
COLABFOLD_NUM_MODELS=1
COLABFOLD_GPU_PARTITION="${SLURM_PARTITION_GPU}"
COLABFOLD_GPU_ACCOUNT="${SLURM_ACCOUNT}"
COLABFOLD_GPU_CPUS=10
COLABFOLD_GPU_MEM="32G"
COLABFOLD_GPU_TIME="12:00:00"
COLABFOLD_CUDA_MODULE="lib/cuda/12.4"

# Runtime profile
# Options currently available:
# - truba_barbun_cuda
# - truba_akya_cuda
COLABFOLD_PROFILE="truba_barbun_cuda"

# Mode-specific ColabFold batch policy
# target_batches mode is preferred for large runs.
TEST_TARGET_BATCHES=1
REGRESSION_TARGET_BATCHES=4
FULL_TARGET_BATCHES=8
